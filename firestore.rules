rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Authenticated users only
    function isAuth() {
      return request.auth != null;
    }

    // Policies: any auth'd user can read; only creator can write (extend as needed)
    match /policies/{policyId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Assignments: any auth'd user can read; any auth'd user can write (admin-only in prod)
    match /assignments/{assignmentId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Acknowledgments: users can read all; users can only write their own
    match /acknowledgments/{ackId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == resource.data.userId
        || isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // Users: each user can read/write their own doc; admins can read all
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }
  }
}
